# Helm dependency archives (downloaded by `helm dependency build`)
charts/agentops-platform/charts/*.tgz

# Chart.lock — not committed. Chart.yaml pins exact versions (no ranges),
# so the lock only adds digests which change on every OCI push. Regenerated
# by `helm dependency update` in the release workflow.
charts/agentops-platform/Chart.lock

# Packaged chart output
dist/

# OS files
.DS_Store
